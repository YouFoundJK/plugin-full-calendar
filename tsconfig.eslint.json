{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "jest"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "test_helpers/**/*.ts",
    "test_helpers/**/*.tsx",
    "__mocks__/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "build", "main.js"]
}
