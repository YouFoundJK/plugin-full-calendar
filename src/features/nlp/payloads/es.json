{
  "version": 2,
  "locale": "es",
  "rules": [
    {
      "name": "navigate_week",
      "regex": "^(?:abrir|ver|mostrar)\\s+(?:la\\s+)?vista\\s+(?:semanal|semana)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(NAVIGATE_WEEK)"]
    },
    {
      "name": "navigate_month",
      "regex": "^(?:abrir|ver|mostrar)\\s+(?:la\\s+)?vista\\s+(?:mensual|mes)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(NAVIGATE_MONTH)"]
    },
    {
      "name": "navigate_day",
      "regex": "^(?:abrir|ver|mostrar)\\s+(?:la\\s+)?vista\\s+(?:diaria|día)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(NAVIGATE_DAY)"]
    },
    {
      "name": "navigate_calendar",
      "regex": "^(?:abrir|mostrar)\\s+(?:el\\s+)?calendario\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_CALENDAR)"]
    },
    {
      "name": "navigate_sidebar",
      "regex": "^(?:abrir|mostrar)\\s+(?:la\\s+)?barra\\s+lateral\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_SIDEBAR)"]
    },
    {
      "name": "open_settings",
      "regex": "^(?:abrir|mostrar)\\s+(?:los\\s+)?ajustes\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_SETTINGS)"]
    },
    {
      "name": "open_chrono",
      "regex": "^(?:abrir|mostrar|lanzar)\\s+(?:el\\s+)?(?:chrono|analizador|analyzer|análisis|insights)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_CHRONO)"]
    },
    {
      "name": "show_changelog",
      "regex": "^(?:mostrar|abrir|ver)\\s+(?:el\\s+)?(?:registro\\s+de\\s+cambios|changelog|qué\\s+hay\\s+de\\s+nuevo|notas\\s+de\\s+la\\s+versión)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(SHOW_CHANGELOG)"]
    },
    {
      "name": "reset_cache",
      "regex": "^(?:restablecer|limpiar|vaciar)\\s+(?:el\\s+)?cache\\b",
      "flags": "i",
      "actions": ["SET_INTENT(RESET_CACHE)"]
    },
    {
      "name": "revalidate_remote",
      "regex": "^(?:revalidar|actualizar|recargar|sincronizar)\\s+(?:los\\s+)?calendarios\\b",
      "flags": "i",
      "actions": ["SET_INTENT(REVALIDATE_REMOTE)"]
    },
    {
      "name": "sync_activitywatch",
      "regex": "^(?:sincronizar|lanzar|run)\\s+(?:activitywatch|activity\\s+watch|aw)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(SYNC_ACTIVITYWATCH)"]
    },
    {
      "name": "goto_date",
      "regex": "^(?:ir\\s+a|ir\\s+al|saltar\\s+a|navegar\\s+a)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(GOTO_DATE)"]
    },
    {
      "name": "new_event",
      "regex": "^(?:nuevo|crear)\\s+(?:un\\s+)?evento\\b",
      "flags": "i",
      "actions": []
    },
    {
      "name": "next_weekday",
      "regex": "\\bpróximo\\s+(lunes|martes|miércoles|jueves|viernes|sábado|domingo)\\b",
      "flags": "i",
      "actions": ["NEXT_WEEKDAY($1)"]
    },
    {
      "name": "next_occurring_day",
      "regex": "\\bel\\s+(\\d{1,2})\\b",
      "flags": "i",
      "actions": ["SET_NEXT_OCCURRING_DAY($1)"]
    },
    {
      "name": "duration_hrs",
      "regex": "\\bpor\\s+(\\d+)\\s+horas?\\b",
      "flags": "i",
      "actions": ["ADD_DURATION($1,0)"]
    },
    {
      "name": "duration_mins",
      "regex": "\\bpor\\s+(\\d+)\\s+minutos?\\b",
      "flags": "i",
      "actions": ["ADD_DURATION(0,$1)"]
    },
    {
      "name": "time_noon",
      "regex": "\\bal\\s+mediodía\\b",
      "flags": "i",
      "actions": ["SET_TIME(12,0,\"\")"]
    },
    {
      "name": "time_midnight",
      "regex": "\\ba\\s+medianoche\\b",
      "flags": "i",
      "actions": ["SET_TIME(0,0,\"\")"]
    },
    {
      "name": "in_minutes",
      "regex": "\\ben\\s+(\\d+)\\s+minutos?\\b",
      "flags": "i",
      "actions": ["ADD_MINUTES($1)"]
    },
    {
      "name": "in_hours",
      "regex": "\\ben\\s+(\\d+)\\s+horas?\\b",
      "flags": "i",
      "actions": ["ADD_HOURS($1)"]
    },
    {
      "name": "in_days",
      "regex": "\\ben\\s+(\\d+)\\s+días?\\b",
      "flags": "i",
      "actions": ["ADD_DAYS($1)"]
    },
    {
      "name": "in_weeks",
      "regex": "\\ben\\s+(\\d+)\\s+semanas?\\b",
      "flags": "i",
      "actions": ["ADD_WEEKS($1)"]
    },
    {
      "name": "time_exact",
      "regex": "(?:a\\s+las\\s+)?(\\d{1,2})(?::(\\d{2}))?\\b",
      "flags": "i",
      "actions": ["SET_TIME($1,$2,\"\")"]
    },
    {
      "name": "tomorrow",
      "regex": "\\b(mañana)\\b",
      "flags": "i",
      "actions": ["ADD_DAYS(1)"]
    },
    {
      "name": "today",
      "regex": "\\b(hoy)\\b",
      "flags": "i",
      "actions": ["ADD_DAYS(0)"]
    },
    {
      "name": "yesterday",
      "regex": "\\b(ayer)\\b",
      "flags": "i",
      "actions": ["SUBTRACT_DAYS(1)"]
    },
    {
      "name": "target_calendar",
      "regex": "\\ben\\s+el\\s+calendario\\s+([\\w\\-\\/ ]{2,50})\\b",
      "flags": "i",
      "actions": ["SET_TARGET($1)"]
    },
    {
      "name": "recur_daily",
      "regex": "\\b(?:cada\\s+día|diariamente)\\b",
      "flags": "i",
      "actions": ["SET_RECURRENCE(DAILY,1)"]
    },
    {
      "name": "recur_weekly_weekday",
      "regex": "\\btodos\\s+los\\s+(lunes|martes|miércoles|jueves|viernes|sábado|domingo)\\b",
      "flags": "i",
      "actions": ["SET_RECURRENCE(WEEKLY,1,$1)"]
    }
  ]
}
