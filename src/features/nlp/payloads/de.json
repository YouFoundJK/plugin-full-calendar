{
  "version": 3,
  "locale": "de",
  "categoryParsing": {
    "spokenDelimiterRegex": "\\s+(?:dash|bindestrich)\\s+",
    "spokenDelimiterFlags": "gi",
    "explicitCategoryRegex": "\\bkategorie\\s+(.+)$",
    "explicitCategoryFlags": "i"
  },
  "rules": [
    {
      "name": "navigate_week",
      "regex": "^(?:öffne|zeige|ansicht)\\s+(?:die\\s+)?(?:wöchentliche|woche)\\s+(?:ansicht|kalender)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(NAVIGATE_WEEK)"]
    },
    {
      "name": "navigate_month",
      "regex": "^(?:öffne|zeige|ansicht)\\s+(?:die\\s+)?(?:monatliche|monat)\\s+(?:ansicht|kalender)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(NAVIGATE_MONTH)"]
    },
    {
      "name": "navigate_day",
      "regex": "^(?:öffne|zeige|ansicht)\\s+(?:die\\s+)?(?:tägliche|tag)\\s+(?:ansicht|kalender)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(NAVIGATE_DAY)"]
    },
    {
      "name": "navigate_calendar",
      "regex": "^(?:öffne|zeige)\\s+(?:den\\s+)?kalender\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_CALENDAR)"]
    },
    {
      "name": "navigate_sidebar",
      "regex": "^(?:öffne|zeige)\\s+(?:die\\s+)?seitenleiste\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_SIDEBAR)"]
    },
    {
      "name": "open_settings",
      "regex": "^(?:öffne|zeige)\\s+(?:die\\s+)?einstellungen\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_SETTINGS)"]
    },
    {
      "name": "open_chrono",
      "regex": "^(?:öffne|zeige|starte)\\s+(?:den\\s+)?(?:chrono|analysator|analyzer|analyse|insights)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_CHRONO)"]
    },
    {
      "name": "show_changelog",
      "regex": "^(?:zeige|öffne)\\s+(?:das\\s+)?(?:änderungsprotokoll|changelog|was\\s+ist\\s+neu|versionshinweise)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(SHOW_CHANGELOG)"]
    },
    {
      "name": "reset_cache",
      "regex": "^(?:lösche|leere|reset)\\s+(?:den\\s+)?(?:ereignis-?)?cache\\b",
      "flags": "i",
      "actions": ["SET_INTENT(RESET_CACHE)"]
    },
    {
      "name": "revalidate_remote",
      "regex": "^(?:aktualisiere|revalidiere|neu\\s+laden|synchronisiere)\\s+(?:die\\s+)?(?:remote-?)?kalender\\b",
      "flags": "i",
      "actions": ["SET_INTENT(REVALIDATE_REMOTE)"]
    },
    {
      "name": "sync_activitywatch",
      "regex": "^(?:synchronisiere|starte|run)\\s+(?:activitywatch|activity\\s+watch|aw)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(SYNC_ACTIVITYWATCH)"]
    },
    {
      "name": "goto_date",
      "regex": "^(?:gehe\\s+zu|gehe\\s+zum|springe\\s+zu|navigiere\\s+zu)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(GOTO_DATE)"]
    },
    {
      "name": "new_event",
      "regex": "^(?:neues|erstelle)\\s+(?:ein\\s+)?ereignis\\b",
      "flags": "i",
      "actions": []
    },
    {
      "name": "next_weekday",
      "regex": "\\bnächsten?\\s+(montag|dienstag|mittwoch|donnerstag|freitag|samstag|sonntag)\\b",
      "flags": "i",
      "actions": ["NEXT_WEEKDAY($1)"]
    },
    {
      "name": "next_occurring_day",
      "regex": "\\bam\\s+(\\d{1,2})\\.\\b",
      "flags": "i",
      "actions": ["SET_NEXT_OCCURRING_DAY($1)"]
    },
    {
      "name": "duration_hrs",
      "regex": "\\bfür\\s+(\\d+)\\s+(?:std|stunden)\\b",
      "flags": "i",
      "actions": ["ADD_DURATION($1,0)"]
    },
    {
      "name": "duration_mins",
      "regex": "\\bfür\\s+(\\d+)\\s+(?:min|minuten)\\b",
      "flags": "i",
      "actions": ["ADD_DURATION(0,$1)"]
    },
    {
      "name": "time_noon",
      "regex": "\\bum\\s+mittags?\\b",
      "flags": "i",
      "actions": ["SET_TIME(12,0,\"\")"]
    },
    {
      "name": "time_midnight",
      "regex": "\\bum\\s+mitternacht\\b",
      "flags": "i",
      "actions": ["SET_TIME(0,0,\"\")"]
    },
    {
      "name": "in_minutes",
      "regex": "\\bin\\s+(\\d+)\\s+minuten?\\b",
      "flags": "i",
      "actions": ["ADD_MINUTES($1)"]
    },
    {
      "name": "in_hours",
      "regex": "\\bin\\s+(\\d+)\\s+stunden?\\b",
      "flags": "i",
      "actions": ["ADD_HOURS($1)"]
    },
    {
      "name": "in_days",
      "regex": "\\bin\\s+(\\d+)\\s+tagen?\\b",
      "flags": "i",
      "actions": ["ADD_DAYS($1)"]
    },
    {
      "name": "in_weeks",
      "regex": "\\bin\\s+(\\d+)\\s+wochen?\\b",
      "flags": "i",
      "actions": ["ADD_WEEKS($1)"]
    },
    {
      "name": "time_exact",
      "regex": "(?:\\bum\\s+)?(\\d{1,2})(?::(\\d{2}))?\\s*(uhr)?\\b",
      "flags": "i",
      "actions": ["SET_TIME($1,$2,\"\")"]
    },
    {
      "name": "next_week",
      "regex": "\\bnächste\\s+woche\\b",
      "flags": "i",
      "actions": ["ADD_DAYS(7)"]
    },
    {
      "name": "next_month",
      "regex": "\\bnächsten\\s+monat\\b",
      "flags": "i",
      "actions": ["ADD_DAYS(30)"]
    },
    {
      "name": "tomorrow",
      "regex": "\\b(morgen)\\b",
      "flags": "i",
      "actions": ["ADD_DAYS(1)"]
    },
    {
      "name": "today",
      "regex": "\\b(heute)\\b",
      "flags": "i",
      "actions": ["ADD_DAYS(0)"]
    },
    {
      "name": "yesterday",
      "regex": "\\b(gestern)\\b",
      "flags": "i",
      "actions": ["SUBTRACT_DAYS(1)"]
    },
    {
      "name": "target_calendar",
      "regex": "\\bim\\s+([\\w\\-\\/ ]{2,50})\\s+kalender\\b",
      "flags": "i",
      "actions": ["SET_TARGET($1)"]
    },
    {
      "name": "recur_daily",
      "regex": "\\b(?:jeden\\s+tag|täglich)\\b",
      "flags": "i",
      "actions": ["SET_RECURRENCE(DAILY,1)"]
    },
    {
      "name": "recur_weekly_weekday",
      "regex": "\\bjeden\\s+(montag|dienstag|mittwoch|donnerstag|freitag|samstag|sonntag)\\b",
      "flags": "i",
      "actions": ["SET_RECURRENCE(WEEKLY,1,$1)"]
    }
  ]
}
