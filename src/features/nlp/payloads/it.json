{
  "version": 3,
  "locale": "it",
  "categoryParsing": {
    "spokenDelimiterRegex": "\\s+(?:trattino|dash)\\s+",
    "spokenDelimiterFlags": "gi",
    "explicitCategoryRegex": "\\bcategoria\\s+(.+)$",
    "explicitCategoryFlags": "i"
  },
  "rules": [
    {
      "name": "navigate_week",
      "regex": "^(?:apri|vedi|mostra)\\s+(?:la\\s+)?vista\\s+(?:settimanale|settimana)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(NAVIGATE_WEEK)"]
    },
    {
      "name": "navigate_month",
      "regex": "^(?:apri|vedi|mostra)\\s+(?:la\\s+)?vista\\s+(?:mensile|mese)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(NAVIGATE_MONTH)"]
    },
    {
      "name": "navigate_day",
      "regex": "^(?:apri|vedi|mostra)\\s+(?:la\\s+)?vista\\s+(?:giornaliera|giorno)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(NAVIGATE_DAY)"]
    },
    {
      "name": "navigate_calendar",
      "regex": "^(?:apri|mostra)\\s+(?:il\\s+)?calendario\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_CALENDAR)"]
    },
    {
      "name": "navigate_sidebar",
      "regex": "^(?:apri|mostra)\\s+(?:la\\s+)?barra\\s+laterale\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_SIDEBAR)"]
    },
    {
      "name": "open_settings",
      "regex": "^(?:apri|mostra)\\s+(?:le\\s+)?impostazioni\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_SETTINGS)"]
    },
    {
      "name": "open_chrono",
      "regex": "^(?:apri|mostra|lancia)\\s+(?:il\\s+)?(?:chrono|analizzatore|analyzer|analisi|insights)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_CHRONO)"]
    },
    {
      "name": "show_changelog",
      "regex": "^(?:mostra|apri|vedi)\\s+(?:il\\s+)?(?:registro\\s+modifiche|changelog|novità|note\\s+di\\s+rilascio)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(SHOW_CHANGELOG)"]
    },
    {
      "name": "reset_cache",
      "regex": "^(?:reimposta|pulisci|svuota)\\s+(?:la\\s+)?cache\\b",
      "flags": "i",
      "actions": ["SET_INTENT(RESET_CACHE)"]
    },
    {
      "name": "revalidate_remote",
      "regex": "^(?:convalida|aggiorna|ricarica|sincronizza)\\s+(?:i\\s+)?calendari\\b",
      "flags": "i",
      "actions": ["SET_INTENT(REVALIDATE_REMOTE)"]
    },
    {
      "name": "sync_activitywatch",
      "regex": "^(?:sincronizza|lancia|run)\\s+(?:activitywatch|activity\\s+watch|aw)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(SYNC_ACTIVITYWATCH)"]
    },
    {
      "name": "goto_date",
      "regex": "^(?:vai\\s+a|vai\\s+al|vai\\s+alla|salta\\s+a|naviga\\s+verso)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(GOTO_DATE)"]
    },
    {
      "name": "new_event",
      "regex": "^(?:nuovo|crea)\\s+(?:un\\s+)?evento\\b",
      "flags": "i",
      "actions": []
    },
    {
      "name": "next_weekday",
      "regex": "\\bprossimo\\s+(lunedì|martedì|mercoledì|giovedì|venerdì|sabato|domenica)\\b",
      "flags": "i",
      "actions": ["NEXT_WEEKDAY($1)"]
    },
    {
      "name": "next_occurring_day",
      "regex": "\\bil\\s+(\\d{1,2})\\b",
      "flags": "i",
      "actions": ["SET_NEXT_OCCURRING_DAY($1)"]
    },
    {
      "name": "duration_hrs",
      "regex": "\\bper\\s+(\\d+)\\s+ore?\\b",
      "flags": "i",
      "actions": ["ADD_DURATION($1,0)"]
    },
    {
      "name": "duration_mins",
      "regex": "\\bper\\s+(\\d+)\\s+minuti?\\b",
      "flags": "i",
      "actions": ["ADD_DURATION(0,$1)"]
    },
    {
      "name": "time_noon",
      "regex": "\\ba\\s+mezzogiorno\\b",
      "flags": "i",
      "actions": ["SET_TIME(12,0,\"\")"]
    },
    {
      "name": "time_midnight",
      "regex": "\\ba\\s+mezzanotte\\b",
      "flags": "i",
      "actions": ["SET_TIME(0,0,\"\")"]
    },
    {
      "name": "in_minutes",
      "regex": "\\btra\\s+(\\d+)\\s+minuti?\\b",
      "flags": "i",
      "actions": ["ADD_MINUTES($1)"]
    },
    {
      "name": "in_hours",
      "regex": "\\btra\\s+(\\d+)\\s+ore?\\b",
      "flags": "i",
      "actions": ["ADD_HOURS($1)"]
    },
    {
      "name": "in_days",
      "regex": "\\btra\\s+(\\d+)\\s+giorni?\\b",
      "flags": "i",
      "actions": ["ADD_DAYS($1)"]
    },
    {
      "name": "in_weeks",
      "regex": "\\btra\\s+(\\d+)\\s+settimane?\\b",
      "flags": "i",
      "actions": ["ADD_WEEKS($1)"]
    },
    {
      "name": "time_exact",
      "regex": "(?:alle\\s+)?(\\d{1,2})(?::(\\d{2}))?\\b",
      "flags": "i",
      "actions": ["SET_TIME($1,$2,\"\")"]
    },
    {
      "name": "tomorrow",
      "regex": "\\b(domani)\\b",
      "flags": "i",
      "actions": ["ADD_DAYS(1)"]
    },
    {
      "name": "today",
      "regex": "\\b(oggi)\\b",
      "flags": "i",
      "actions": ["ADD_DAYS(0)"]
    },
    {
      "name": "yesterday",
      "regex": "\\b(ieri)\\b",
      "flags": "i",
      "actions": ["SUBTRACT_DAYS(1)"]
    },
    {
      "name": "target_calendar",
      "regex": "\\bnel\\s+calendario\\s+([\\w\\-\\/ ]{2,50})\\b",
      "flags": "i",
      "actions": ["SET_TARGET($1)"]
    },
    {
      "name": "recur_daily",
      "regex": "\\b(?:ogni\\s+giorno|quotidianamente)\\b",
      "flags": "i",
      "actions": ["SET_RECURRENCE(DAILY,1)"]
    },
    {
      "name": "recur_weekly_weekday",
      "regex": "\\bogni\\s+(lunedì|martedì|mercoledì|giovedì|venerdì|sabato|domenica)\\b",
      "flags": "i",
      "actions": ["SET_RECURRENCE(WEEKLY,1,$1)"]
    }
  ]
}
