{
  "version": 2,
  "locale": "fr",
  "rules": [
    {
      "name": "navigate_week",
      "regex": "^(?:ouvrir|voir|afficher)\\s+(?:la\\s+)?vue\\s+(?:hebdomadaire|semaine)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(NAVIGATE_WEEK)"]
    },
    {
      "name": "navigate_month",
      "regex": "^(?:ouvrir|voir|afficher)\\s+(?:la\\s+)?vue\\s+(?:mensuelle|mois)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(NAVIGATE_MONTH)"]
    },
    {
      "name": "navigate_day",
      "regex": "^(?:ouvrir|voir|afficher)\\s+(?:la\\s+)?vue\\s+(?:quotidienne|jour)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(NAVIGATE_DAY)"]
    },
    {
      "name": "navigate_calendar",
      "regex": "^(?:ouvrir|afficher)\\s+(?:le\\s+)?calendrier\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_CALENDAR)"]
    },
    {
      "name": "navigate_sidebar",
      "regex": "^(?:ouvrir|afficher)\\s+(?:la\\s+)?barre\\s+latérale\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_SIDEBAR)"]
    },
    {
      "name": "open_settings",
      "regex": "^(?:ouvrir|afficher)\\s+(?:les\\s+)?paramètres\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_SETTINGS)"]
    },
    {
      "name": "open_chrono",
      "regex": "^(?:ouvrir|afficher|lancer)\\s+(?:l')?(?:chrono|analyseur|analyzer|analyse|insights)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(OPEN_CHRONO)"]
    },
    {
      "name": "show_changelog",
      "regex": "^(?:afficher|ouvrir|voir)\\s+(?:le\\s+)?(?:journal\\s+des\\s+modifications|changelog|notes\\s+de\\s+mise\\s+à\\s+jour)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(SHOW_CHANGELOG)"]
    },
    {
      "name": "reset_cache",
      "regex": "^(?:réinitialiser|effacer|vider)\\s+(?:le\\s+)?cache\\b",
      "flags": "i",
      "actions": ["SET_INTENT(RESET_CACHE)"]
    },
    {
      "name": "revalidate_remote",
      "regex": "^(?:réactualiser|revalider|recharger|synchroniser)\\s+(?:les\\s+)?calendriers\\b",
      "flags": "i",
      "actions": ["SET_INTENT(REVALIDATE_REMOTE)"]
    },
    {
      "name": "sync_activitywatch",
      "regex": "^(?:synchroniser|lancer|run)\\s+(?:activitywatch|activity\\s+watch|aw)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(SYNC_ACTIVITYWATCH)"]
    },
    {
      "name": "goto_date",
      "regex": "^(?:aller\\s+à|aller\\s+au|sauter\\s+à|naviguer\\s+vers)\\b",
      "flags": "i",
      "actions": ["SET_INTENT(GOTO_DATE)"]
    },
    {
      "name": "new_event",
      "regex": "^(?:nouvel|créer)\\s+(?:un\\s+)?événement\\b",
      "flags": "i",
      "actions": []
    },
    {
      "name": "next_weekday",
      "regex": "\\b(lundi|mardi|mercredi|jeudi|vendredi|samedi|dimanche)\\s+prochain\\b",
      "flags": "i",
      "actions": ["NEXT_WEEKDAY($1)"]
    },
    {
      "name": "next_occurring_day",
      "regex": "\\ble\\s+(\\d{1,2})\\b",
      "flags": "i",
      "actions": ["SET_NEXT_OCCURRING_DAY($1)"]
    },
    {
      "name": "duration_hrs",
      "regex": "\\b(?:pendant|pour)\\s+(\\d+)\\s+heures?\\b",
      "flags": "i",
      "actions": ["ADD_DURATION($1,0)"]
    },
    {
      "name": "duration_mins",
      "regex": "\\b(?:pendant|pour)\\s+(\\d+)\\s+minutes?\\b",
      "flags": "i",
      "actions": ["ADD_DURATION(0,$1)"]
    },
    {
      "name": "time_noon",
      "regex": "\\bà\\s+midi\\b",
      "flags": "i",
      "actions": ["SET_TIME(12,0,\"\")"]
    },
    {
      "name": "time_midnight",
      "regex": "\\bà\\s+minuit\\b",
      "flags": "i",
      "actions": ["SET_TIME(0,0,\"\")"]
    },
    {
      "name": "in_minutes",
      "regex": "\\bdans\\s+(\\d+)\\s+minutes?\\b",
      "flags": "i",
      "actions": ["ADD_MINUTES($1)"]
    },
    {
      "name": "in_hours",
      "regex": "\\bdans\\s+(\\d+)\\s+heures?\\b",
      "flags": "i",
      "actions": ["ADD_HOURS($1)"]
    },
    {
      "name": "in_days",
      "regex": "\\bdans\\s+(\\d+)\\s+jours?\\b",
      "flags": "i",
      "actions": ["ADD_DAYS($1)"]
    },
    {
      "name": "in_weeks",
      "regex": "\\bdans\\s+(\\d+)\\s+semaines?\\b",
      "flags": "i",
      "actions": ["ADD_WEEKS($1)"]
    },
    {
      "name": "time_exact",
      "regex": "(?:à\\s+)?(\\d{1,2})(?:h|:(\\d{2}))?\\b",
      "flags": "i",
      "actions": ["SET_TIME($1,$2,\"\")"]
    },
    {
      "name": "tomorrow",
      "regex": "\\b(demain)\\b",
      "flags": "i",
      "actions": ["ADD_DAYS(1)"]
    },
    {
      "name": "today",
      "regex": "\\b(aujourd'hui)\\b",
      "flags": "i",
      "actions": ["ADD_DAYS(0)"]
    },
    {
      "name": "yesterday",
      "regex": "\\b(hier)\\b",
      "flags": "i",
      "actions": ["SUBTRACT_DAYS(1)"]
    },
    {
      "name": "target_calendar",
      "regex": "\\bdans\\s+le\\s+calendrier\\s+([\\w\\-\\/ ]{2,50})\\b",
      "flags": "i",
      "actions": ["SET_TARGET($1)"]
    },
    {
      "name": "recur_daily",
      "regex": "\\b(?:chaque\\s+jour|quotidiennement)\\b",
      "flags": "i",
      "actions": ["SET_RECURRENCE(DAILY,1)"]
    },
    {
      "name": "recur_weekly_weekday",
      "regex": "\\btous\\s+les\\s+(lundi|mardi|mercredi|jeudi|vendredi|samedi|dimanche)\\b",
      "flags": "i",
      "actions": ["SET_RECURRENCE(WEEKLY,1,$1)"]
    }
  ]
}
