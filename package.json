{
    "name": "full-calendar-remastered",
    "version": "0.13.1",
    "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
    "description": "Obsidian integration with Full Calendar (fullcalendar.io)",
    "main": "main.js",
    "scripts": {
        "preinstall": "npx only-allow pnpm",
        "dev": "node esbuild.config.mjs",
        "dev:vault": "node esbuild.config.mjs",
        "build": "node esbuild.config.mjs production",
        "prod": "pnpm run compile && node esbuild.config.mjs production",
        "version": "node version-bump.mjs && git add manifest.json versions.json",
        "lint": "eslint \"src/**/*.{ts,tsx}\" \"test_helpers/**/*.{ts,tsx}\" \"__mocks__/**/*.ts\" && eslint -c eslint.css.config.mjs \"src/**/*.css\"",
        "lint:eslint": "eslint \"src/**/*.{ts,tsx}\" \"test_helpers/**/*.{ts,tsx}\" \"__mocks__/**/*.ts\" -o lint_report.txt --no-color && eslint -c eslint.css.config.mjs \"src/**/*.css\" --no-color",
        "lt-es": "eslint \"src/**/*.{ts,tsx}\" \"test_helpers/**/*.{ts,tsx}\" \"__mocks__/**/*.ts\" -o lint_report.txt --no-color && eslint -c eslint.css.config.mjs \"src/**/*.css\" --no-color && node tools/check-and-prune-i18n.mjs",
        "lint:fix": "eslint \"src/**/*.{ts,tsx}\" \"test_helpers/**/*.{ts,tsx}\" \"__mocks__/**/*.ts\" --fix && eslint -c eslint.css.config.mjs \"src/**/*.css\" --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "fl": "prettier --config .prettierrc.json --write src/**/*.ts*",
        "compile": "tsc -noEmit --skipLibCheck",
        "prepare": "husky install",
        "test": "jest --ci --silent=true",
        "test-update": "jest --silent=false --updateSnapshot",
        "test-dev": "jest --watch",
        "coverage": "jest --coverage",
        "prod:release": "pnpm run prod && node -e \"const fs=require('fs');const path=require('path');const root=process.cwd();const outputDir=path.join(root,'release-artifacts');const builtDir=path.join(root,'obsidian-dev-vault','.obsidian','plugins','full-calendar-remastered');fs.rmSync(outputDir,{recursive:true,force:true});fs.mkdirSync(outputDir,{recursive:true});for(const fileName of ['main.js','styles.css']){fs.copyFileSync(path.join(builtDir,fileName),path.join(outputDir,fileName));}fs.copyFileSync(path.join(root,'manifest.json'),path.join(outputDir,'manifest.json'));\"",
        "ra": "prettier --config .prettierrc.json --write src/**/*.ts* && pnpm run compile && eslint src -o lint_report.txt --no-color && eslint -c eslint.css.config.mjs \"src/**/*.css\" -o css_report.txt --no-color && node tools/check-and-prune-i18n.mjs && jest --ci --silent=true"
    },
    "keywords": [],
    "author": {
        "name": "Jovi Koikkara | Davis Haupt",
        "email": "jovikoikkara@destyleer.in.net",
        "url": "https://github.com/YouFoundJK"
    },
    "license": "GNU General Public License",
    "devDependencies": {
        "@eslint/compat": "^2.1.0",
        "@eslint/css": "^1.2.0",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^9.39.4",
        "@eslint/json": "^0.14.0",
        "@types/color": "^4.2.1",
        "@types/jest": "^30.0.0",
        "@types/luxon": "^3.7.1",
        "@types/node": "^25.7.0",
        "@types/plotly.js": "^3.0.10",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "esbuild": "0.28.0",
        "eslint": "^9.39.4",
        "eslint-plugin-obsidianmd": "^0.3.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "fast-check": "^3.23.2",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "jest": "^30.4.2",
        "jest-environment-jsdom": "^30.4.1",
        "jest-mock-extended": "^4.0.1",
        "moment": "^2.30.1",
        "obsidian": "^1.12.3",
        "prettier": "^3.8.3",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "ts-jest": "^29.4.9",
        "tslib": "2.8.1",
        "typescript": "5.4.5",
        "typescript-eslint": "^8.59.3",
        "yaml": "^2.9.0",
        "zod-fast-check": "^0.10.1"
    },
    "dependencies": {
        "@fullcalendar/core": "^6.1.20",
        "@fullcalendar/daygrid": "^6.1.20",
        "@fullcalendar/google-calendar": "^6.1.20",
        "@fullcalendar/icalendar": "^6.1.20",
        "@fullcalendar/interaction": "^6.1.20",
        "@fullcalendar/list": "^6.1.20",
        "@fullcalendar/luxon3": "^6.1.20",
        "@fullcalendar/resource": "^6.1.20",
        "@fullcalendar/resource-timeline": "^6.1.20",
        "@fullcalendar/rrule": "^6.1.20",
        "@fullcalendar/timegrid": "^6.1.20",
        "@ladle/react": "^5.1.1",
        "@types/deep-equal": "^1.0.4",
        "@types/ical": "^0.8.3",
        "color": "^5.0.3",
        "esbuild-css-modules-plugin": "^3.1.5",
        "flatpickr": "^4.6.13",
        "i18next": "^26.1.0",
        "ical": "^0.8.0",
        "ical.js": "^1.5.0",
        "luxon": "^3.7.2",
        "obsidian-daily-notes-interface": "^0.9.5",
        "plotly.js": "^3.5.1",
        "preact": "^10.29.1",
        "rrule": "^2.8.1",
        "tsdav": "^2.2.2",
        "zod": "^3.25.76"
    },
    "overrides": {
        "minimatch": "^10.2.1",
        "react-inspector": {
            "react": "$react",
            "react-dom": "$react-dom"
        }
    }
}
